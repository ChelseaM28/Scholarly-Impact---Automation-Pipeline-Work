def institution_similarity(data):
    davis_affiliations = ["University of California, Davis", "UC Davis", "UCD", "UC Davis School of Medicine", 
                          "School of Veterinary Medicine", "Crocker Nuclear Laboratory", "Bodega Marine Laboratory", 
                          "UC Davis Genome Center", "UC Davis Health System", "UC Davis Health", "UC Davis Medical Center", 
                          "UC Davis School of Nursing", "UC Davis School of Pharmacy", "UC Davis School of Veterinary Medicine", 
                          "UC Davis College of Agricultural and Environmental Sciences", "UC Davis College of Biological Sciences", 
                          "UC Davis College of Engineering", "UC Davis College of Letters and Science", "UC Davis Graduate School of Management", 
                          "UC Davis Extension", "UC Davis Institute of Transportation Studies", "UC Davis John Muir Institute of the Environment", 
                          "UC Davis Tahoe Environmental Research Center", "UC Davis Center for Watershed Sciences", "UC Davis One Health Institute"]
    affiliated = 0
    affiliations = []
    for ucmps_institution in data:
        if ucmps_institution in davis_affiliations:
            affiliated = 1
        else:
            affiliated = 0
        affiliations.append(affiliated)
    print(f"Institution similarity results (1 for affiliated with UC Davis, 0 for not affiliated): {affiliations}")
    return affiliations

