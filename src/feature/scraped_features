brown_ic = wordnet_ic.ic('ic-brown.dat')

#NLTK implementation
def research_area_similarity(data):
    #PLAN TO REPLACE ALL FOR LOOPS WITH NUMPY FUNCTIONS
    wun_similarity_scores = [] #actually wup similarity. Returns score from 0 to 1. Based on sysnonym sets/taxonomy
    resnik_similarity_scores = [] #does not scale 0 to 1
    lin_similarity_scores = [] #does not scale 0 to 1
    nltk_scores = []

    #This for loop will create similarity scores using all three methods
    for ucmps_field, scopus_field in data:
        #Data clean. Get rid of the phrase "science"
        ucmps_field = ucmps_field.split()[0:2]
        scopus_field = scopus_field.split()[0:2]
        
        ucmps_synsets_first = wn.synsets(ucmps_field[0])
        scopus_synsets_first = wn.synsets(scopus_field[0])
    
        ucmps_synsets_second = wn.synsets(ucmps_field[1]) if len(ucmps_field) > 1 else []
        scopus_synsets_second = wn.synsets(scopus_field[1]) if len(scopus_field) > 1 else []

        

        #I need to match either the first or second token in the field to get a strong 
        # signal of similarity, since some fields are listed as "biology" while 
        # others are just "wildlife biology".
        try:
            similarity_first_to_first = ucmps_synsets_first[0].wup_similarity(scopus_synsets_first[0])
            resnik_first_to_first = wn.res_similarity(ucmps_synsets_first[0], scopus_synsets_first[0], ic=brown_ic)
            #ucmpssynsets.wup versus wn.wup_similarity - I think I need to use wn.wup_similarity because it can handle 
            # cases where one of the synsets is missing (e.g. if the field is not recognized as a valid word in WordNet), 
            # whereas the method on the synset object will throw an error in that case.
            lin_first_to_first = wn.lin_similarity(ucmps_synsets_first[0], scopus_synsets_first[0], ic=brown_ic)
            
        except Exception as e:
  
            similarity_first_to_first = "error"
            resnik_first_to_first = "error"
            lin_first_to_first = "error"
            
        try:
            if scopus_synsets_second[0].name() != 'Science' and scopus_synsets_second[0].name()  != 'Sciences':
                similarity_first_to_second = ucmps_synsets_first[0].wup_similarity(scopus_synsets_second[0])
                resnik_first_to_second = wn.res_similarity(ucmps_synsets_first[0], scopus_synsets_second[0], ic=brown_ic)
                lin_first_to_second = wn.lin_similarity(ucmps_synsets_first[0], scopus_synsets_second[0], ic=brown_ic)
               
            else:
                similarity_first_to_second = -1
                resnik_first_to_second = -1
                lin_first_to_second = -1

        except Exception as e:

            similarity_first_to_second = "error"
            resnik_first_to_second = "error"
            lin_first_to_second = "error"
        try:
            if ucmps_synsets_second[0].name() != 'Science' and ucmps_synsets_second[0].name() != 'Sciences':
                similarity_second_to_first = ucmps_synsets_second[0].wup_similarity(scopus_synsets_first[0])  
                resnik_second_to_first = wn.res_similarity(ucmps_synsets_second[0], scopus_synsets_first[0], ic=brown_ic)
                lin_second_to_first = wn.lin_similarity(ucmps_synsets_second[0], scopus_synsets_first[0], ic=brown_ic)
            else:
                similarity_second_to_first = -1
                resnik_second_to_first = -1
                lin_second_to_first = -1
        except Exception as e:

            similarity_second_to_first = "error"
            resnik_second_to_first = "error"
            lin_second_to_first = "error"
        try:
            if ucmps_synsets_second[0].name() != 'Science' and ucmps_synsets_second[0].name() != 'Sciences' and scopus_synsets_second[0].name() != 'Science' and scopus_synsets_second[0].name() != 'Sciences':
                similarity_second_to_second = ucmps_synsets_second[0].wup_similarity(scopus_synsets_second[0])
                resnik_second_to_second = wn.res_similarity(ucmps_synsets_second[0], scopus_synsets_second[0], ic=brown_ic)
                lin_second_to_second = wn.lin_similarity(ucmps_synsets_second[0], scopus_synsets_second[0], ic=brown_ic)
            else:
                similarity_second_to_second = -1
                resnik_second_to_second = -1     
                lin_second_to_second = -1

        except Exception as e:

            similarity_second_to_second = "error"
            resnik_second_to_second = "error"
            lin_second_to_second = "error"
            
        
        wun_similarity_scores.append([similarity_first_to_first, similarity_first_to_second, 
                                      similarity_second_to_first, similarity_second_to_second])
        resnik_similarity_scores.append([resnik_first_to_first,resnik_first_to_second,
                                         resnik_second_to_first,resnik_second_to_second])
        lin_similarity_scores.append([lin_first_to_first,lin_first_to_second,
                                      lin_second_to_first,lin_second_to_second])
    

    wun_array = np.array(wun_similarity_scores) 
    print(f"wun_arrays for all data:\n{wun_array}")
    res_array = np.array(resnik_similarity_scores) 
    lin_array = np.array(lin_similarity_scores)

    #1. Use boolean indexing to filter out errors. Replace None with 0
    #2. THEN correct against arbitrary value.correct all values <.25 to 0
    for row in range(wun_array.shape[0]):
        for column in range(wun_array.shape[1]):
            #Part 1
            if wun_array[row,column] == 'error' or type(wun_array[row,column]) == None:
                wun_array[row, column] = 0
            # Part 2
            if float(wun_array[row,column]) > .25: 
                wun_array[row,column] = .5
            else:
                wun_array[row,column] = 0 
            if float(wun_array[row,column]) > .5:
                wun_array[row,column] = 1
            
    for row in range(res_array.shape[0]):
        for column in range(res_array.shape[1]):
            if res_array[row,column] == 'error' or type(res_array[row,column]) == None:
                res_array[row, column] = 0
            # Part 2
            if float(res_array[row,column]) > .25: 
                res_array[row,column] = .5
            else:
                res_array[row,column] = 0  
            if float(res_array[row,column]) > .5:
                res_array[row,column] = 1  
            

    for row in range(lin_array.shape[0]):
        for column in range(lin_array.shape[1]):
            if lin_array[row,column] == 'error' or type(lin_array[row,column]) == None:
                lin_array[row, column] = 0
            # Part 2
            if float(lin_array[row,column]) > .25: 
                lin_array[row,column] = .5
            else:
                lin_array[row,column] = 0 
            if float(lin_array[row,column]) > .5:
                lin_array[row,column] = 1
            
    print(f"Error-stripped and 0/1-corrected wun_arrays for all data:\n{wun_array}")
    #NEXT! Sum the contents of each list and replace the list with the sum.
    
    for row in range(wun_array.shape[0]):
        print(wun_array[row,])
        summed_wun_array = [np.sum(wun_array.astype(float), axis = 1)]

    for row in range(res_array.shape[0]):
        summed_res_array = [np.sum(res_array.astype(float), axis = 1)]
        
    for row in range(lin_array.shape[0]):
        summed_lin_array = [np.sum(lin_array.astype(float), axis = 1)]
        
        
    print(f"Summed wun_arrays for all data:\n{summed_wun_array}")

    for i in range(len(summed_wun_array)):
        nltk_scores.append(summed_wun_array[i] + summed_res_array[i] + summed_lin_array[i]) 
   
    print(f"final nltk scores: \n\n{nltk_scores}")

    return nltk_scores
    


#Research Area Similarity Combination
#@Brief: This section will normalize/standardize the institution matching from the 
#research_area_similarity function and the fuzz ratio

def field_similarity_feature(data):
    field_similarity = []
    fuzzy_score = 1
    for ucpms_field, scopus_field in data:
   
        if fuzz.ratio(str(ucpms_field), str(scopus_field)) >= 40:
            fuzzy_score = .5 #Somewhat similar
            if fuzz.ratio(str(ucpms_field), str(scopus_field)) >= 60:
                fuzzy_score = 1 #almost certianly similar
        else:
            fuzzy_score = 0
        #A low score shouldn't be tossed out!!! but a high score should be weighted heavier
    for nltk_score in research_area_similarity(data):
        field_similarity.append(fuzzy_score + nltk_score) #LAST THING TO DO HERE: CLEAN UP THIS LOGIC
    print(field_similarity)
    return field_similarity
